# SurajClaw environment variables.
#
# Copy to `.env` at the repo root (NOT inside surajclaw/) and fill in real
# values. The settings modules load this file via python-dotenv.

# ----- Django ---------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=replace-me-with-a-real-random-secret
ALLOWED_HOSTS=localhost,127.0.0.1,surajclaw.local
CSRF_TRUSTED_ORIGINS=http://localhost,http://surajclaw.local
TIME_ZONE=UTC

# ----- PostgreSQL + pgvector ------------------------------------------------
POSTGRES_DB=surajclaw
POSTGRES_USER=surajclaw
POSTGRES_PASSWORD=surajclaw
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# ----- Redis (Celery broker + Channels layer) ------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ----- Ollama (primary local LLM) ------------------------------------------
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:4b

# ----- Gemini (cloud fallback) ---------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# ----- Embeddings ----------------------------------------------------------
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# ----- Google Workspace OAuth ---------------------------------------------
# Path to downloaded `client_secret_*.json` from Google Cloud Console.
GOOGLE_CLIENT_SECRETS_PATH=./client_secret.json
# Populated after `manage.py google_oauth_login`.
GOOGLE_TOKEN_PATH=./google_token.json

# ----- Google Custom Search (web_search tool) ------------------------------
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# ----- Telegram bot --------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Restrict which Telegram user can talk to the bot (set to your own numeric id).
TELEGRAM_OWNER_ID=

# ----- GitHub webhook (signature verification) -----------------------------
GITHUB_WEBHOOK_SECRET=

# ----- SMTP (optional, for notification fallback when Telegram is down) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ----- Agent / Dream system -----------------------------------------------
DREAM_MIN_SESSIONS=5
DREAM_MIN_HOURS=4
MAX_SUBAGENTS=4

# ----- Filesystem paths ----------------------------------------------------
# Where shell_exec / fs_write tools are allowed to operate.
WORKSPACE_DIR=./workspace
# Where notes_* tools read/write Markdown notes.
NOTES_DIR=./notes
